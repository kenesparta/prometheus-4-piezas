# Copia este archivo a `.env` (o exporta las variables) antes de arrancar.

# Conexión a Redis (obligatoria). Para la nube usa la URL con credenciales:
#   redis://:PASSWORD@HOST:PUERTO  o  rediss://... si el servidor usa TLS.
REDIS_URL=redis://127.0.0.1:6379

# Password inicial del usuario `admin` (rol ADMIN). Se crea al arrancar si no existe.
ADMIN_PASSWORD=123

# Base de la PokeAPI pública.
POKEAPI_URL_BASE=https://pokeapi.co/api/v2

# TTL de la sesión (segundos) y del caché de pokémon en Redis (segundos).
SESION_TTL_SEGUNDOS=86400
CACHE_TTL_SEGUNDOS=600

# Nivel de logs.
RUST_LOG=info,backend=debug
